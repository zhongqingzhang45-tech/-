# ============================================
# LifeOS 环境变量配置示例
# 复制此文件为 .env.local 并填入真实值
# ============================================

# Node 环境
NODE_ENV=development

# Next.js 配置
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# LLM API Keys（至少配置一个）
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 通义千问（阿里云）
DASHSCOPE_API_KEY=your-dashscope-api-key

# 智谱 AI
ZHIPU_API_KEY=your-zhipu-api-key

# 数据库（PostgreSQL）
DATABASE_URL=postgresql://postgres:password@localhost:5432/lifeos?schema=public

# Redis（可选，用于缓存）
# REDIS_URL=redis://localhost:6379

# 第三方服务
# 阿里云短信（用于验证码）
# ALIYUN_ACCESS_KEY_ID=your-access-key
# ALIYUN_ACCESS_KEY_SECRET=your-secret
# ALIYUN_SMS_SIGN_NAME=星野
# ALIYUN_SMS_TEMPLATE_CODE=SMS_xxx

# 日志和监控
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn（用于错误监控）

# 安全
SESSION_SECRET=your-random-session-secret-at-least-32-chars

# Docker 部署
PORT=3000
HOSTNAME=0.0.0.0
