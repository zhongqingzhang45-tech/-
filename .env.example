# ============================================
# LifeOS 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# ============================================

# ---------- 基础配置 ----------
NODE_ENV=production
PORT=3000
APP_PORT=3000
HOSTNAME=0.0.0.0

# ---------- 应用 URL ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ---------- 数据库配置 (PostgreSQL) ----------
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=lifeos_secret_2024
POSTGRES_DB=lifeos
DATABASE_URL=postgresql://lifeos:lifeos_secret_2024@localhost:5432/lifeos?schema=public

# ---------- 安全配置 ----------
SESSION_SECRET=your-random-session-secret-at-least-32-chars-please-change
NEXTAUTH_SECRET=your-super-secret-key-change-in-production-please

# ---------- LLM API Keys（至少配置一个） ----------
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 通义千问（阿里云 DashScope）
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 智谱 AI (GLM)
ZHIPU_API_KEY=your-zhipu-api-key-here

# ---------- Redis（可选，用于缓存） ----------
# REDIS_URL=redis://localhost:6379

# ---------- 日志和监控 ----------
LOG_LEVEL=info
# SENTRY_DSN=your-sentry-dsn-here

# ---------- 第三方服务（可选） ----------
# 阿里云短信（用于验证码）
# ALIYUN_ACCESS_KEY_ID=your-access-key
# ALIYUN_ACCESS_KEY_SECRET=your-secret
# ALIYUN_SMS_SIGN_NAME=星野
# ALIYUN_SMS_TEMPLATE_CODE=SMS_xxx

# ---------- Docker 部署 ----------
COMPOSE_PROJECT_NAME=lifeos
