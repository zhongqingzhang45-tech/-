# ============================================
# LifeOS - Environment Variables
# ============================================

# App URL (used for payment return/notify URLs)
NEXT_PUBLIC_APP_URL=https://ai.lifesys.top

# ============================================
# Alipay 支付宝电脑网站支付配置
# ============================================
# 1. 前往 https://open.alipay.com/ 创建应用
# 2. 开通「电脑网站支付」产品
# 3. 配置 RSA2 密钥对（私钥自行保管，公钥上传到支付宝）
# 4. 填入以下配置

# 支付宝应用 AppID
ALIPAY_APP_ID=2021000000000000

# 支付宝应用私钥 (RSA2)
# ⚠️ 禁止将此文件提交到 GitHub！
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAKCAQEA....\n-----END RSA PRIVATE KEY-----"

# 支付宝公钥
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A....\n-----END PUBLIC KEY-----"

# 支付网关（沙箱用 https://openapi-sandbox.dl.alipaydev.com/gateway.do）
# 正式环境用 https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
