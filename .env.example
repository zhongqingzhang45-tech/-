# 项目配置文件
# 将 .env.example 复制为 .env 并填入真实值

# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 数据库配置
DATABASE_URL=sqlite:///./marketing_agent.db

# 各联盟 API 配置（按需填写）
# 抖音精选联盟
DOUYIN_COOKIE=
DOUYIN_OPEN_API_KEY=

# 视频号优选联盟
WECHAT_VIDEO_APP_ID=
WECHAT_VIDEO_APP_SECRET=

# 淘宝联盟
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_ADZONE_ID=

# 京东联盟
JD_APP_KEY=
JD_APP_SECRET=
JD_SITE_ID=
JD_POSITION_ID=

# 拼多多联盟
PDD_CLIENT_ID=
PDD_CLIENT_SECRET=

# 发布账号配置
# 视频号
WECHAT_VIDEO_ACCOUNT=your_video_channel_account
WECHAT_VIDEO_PASSWORD=

# 小红书
XHS_ACCOUNT=
XHS_PASSWORD=

# 抖音
DOUYIN_ACCOUNT=
DOUYIN_PASSWORD=

# 快手
KUAISHOU_ACCOUNT=
KUAISHOU_PASSWORD=

# Edge-TTS 配音配置
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# 代理配置（可选）
PROXY_HTTP=
PROXY_HTTPS=

# 日志级别
LOG_LEVEL=INFO
